# Temperature-Converter-C
#include<stdio.h>
int main()
{
	char choice;
	float temp,celsius,fahrenheit,kelvin;
	printf("Temperature Converter\n");
	printf("1. Celsius\n");
	printf("2. Fahrenheit\n");
	printf("3. Kelvin\n");
	printf("Enter the unit of the given temperature (C/F/K):");
	scanf("%c",&choice);
	printf("Enter the temperature:");
	scanf("%f",&temp);
	
	switch(choice)
	{
		case 'C': 
				fahrenheit = (temp * 9 / 5) + 32;
				kelvin = temp + 273.15;
				printf("Fahrenheit = %.2f\n",fahrenheit);
				printf("Kelvin = %.2f\n",kelvin);
				break;
		case 'F':
				celsius = (temp - 32) * 5 / 9;
				kelvin = celsius + 273.15;
				printf("Celsius = %.2f\n",celsius);
				printf("Kelvin = %.2f\n",kelvin);
				break;
		case 'K':
				celsius = temp - 273.15;
				fahrenheit = (temp * 9 / 5) + 32;
				printf("Celsius = %.2f\n",celsius);
				printf("Fahrenheit = %.2f\n",fahrenheit);
				break;
		default:
				printf("Invalid choice!\n");
				
		}
		return 0;
} 
A simple C program that converts temperature between Celsius, Fahrenheit, and Kelvin using user input. Developed as part of my programming practice.
